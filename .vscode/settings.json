// Workspace settings. These override user settings and can be overridden by language-specific settings.
{
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.detectIndentation": false,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.insertSpaces": true,
  "editor.indentSize": "tabSize",
  "editor.tabCompletion": "on",
  "files.insertFinalNewline": true,
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.project": true,
    "**/.settings": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "java.checkstyle.configuration": "${workspaceFolder}/api/config/checkstyle/checkstyle.xml",
  "java.checkstyle.version": "13.4.2",
  "java.compile.nullAnalysis.mode": "automatic",
  "java.completion.importOrder": [
    "#",
    "java",
    "javax",
    "org",
    "com",
    "io",
    "api",
    ""
  ],
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.configuration.runtimes": [
    {
      "name": "JavaSE-25",
      "path": "C:\\Program Files\\Eclipse Adoptium\\jdk-25.0.3.9-hotspot"
    }
  ],
  "java.diagnostic.filter": ["**/target/generated-sources/**/*"],
  "java.format.settings.profile": "ArduinoThermoHygrometerCheckstyle",
  "java.format.settings.url": "${workspaceFolder}/api/config/formatter/formatter.xml",
  "java.saveActions.cleanup": true,
  "[java]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.checkstyle": "explicit",
      "source.organizeImports": "explicit",
      "source.unusedImports": "explicit"
    },
    "editor.defaultFormatter": "redhat.java",
    "editor.tabSize": 4
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.unusedImports": "explicit"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.unusedImports": "explicit"
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "xml.format.maxLineWidth": 150,
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
    "editor.tabSize": 2
  },
  "yaml.format.printWidth": 150,
  "yaml.format.trailingComma": false,
  "yaml.schemaStore.enable": false,
  "[yaml]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.autoIndent": "keep",
    "editor.defaultColorDecorators": "never",
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.quickSuggestions": {
      "strings": true,
      "other": true,
      "comments": false
    },
    "editor.tabSize": 2
  }
}
