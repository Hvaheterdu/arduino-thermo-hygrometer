{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "types": [
      "@testing-library/react",
      "@testing-library/dom",
      "node",
      "vite/client",
      "vite-plugin-svgr/client",
      "vitest/globals"
    ],
    "tsBuildInfoFile": "node_modules/.tsconfig/tsconfig.node.tsbuildinfo"
  },
  "exclude": ["../.cert", "../.github", "../.idea", "dist", "node_modules", "../api", "../api/target"],
  "include": ["vite.config.ts"]
}
