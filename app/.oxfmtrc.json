{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "none",
  "printWidth": 120,
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "node_modules",
    "build",
    "coverage",
    "dist",
    "**/*.generated.ts",
    "**/*.d.ts",
    "package-lock.json"
  ]
}
